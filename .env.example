# Website Starter environment placeholders
# Copy to .env.local for local development. Do not commit .env.local.

# Used by sitemap generation. Replace only after an approved domain/staging URL exists.
NEXT_PUBLIC_SITE_URL=https://example.invalid

# Cloudinary media pipeline.
# Cloud name may be public. API key/secret must stay private and should be stored in Vercel/local .env only.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dilwhwhqy
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend email pipeline. Keep private and store in Vercel/local .env only.
RESEND_API_KEY=

# Sanity CMS pipeline. Project/dataset can be public; tokens must stay private.
NEXT_PUBLIC_SANITY_PROJECT_ID=oxczu1g1
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-25
SANITY_PROJECT_ID=oxczu1g1
SANITY_DATASET=production
SANITY_API_VERSION=2026-05-25
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Future placeholders only. Do not fill without explicit approval.
# POSTMARK_SERVER_TOKEN=
# CMS_API_TOKEN=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_ANALYTICS_ID=
